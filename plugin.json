{
  "logo": "logo.png",
  "preload": "preload.js",
  "pluginName": "markurl",
  "description": "URL → Markdown 引用。在任意应用选中 URL，唤起超级面板选择「URL 转 Markdown」即可一键复制。",
  "author": "inscripoem",
  "homepage": "https://github.com/inscripoem/utools-markurl",
  "version": "0.1.0",
  "platform": [
    "win32",
    "darwin",
    "linux"
  ],
  "features": [
    {
      "code": "url2md",
      "explain": "将 URL 解析为 Markdown 引用并复制",
      "cmds": [
        "markurl",
        "mu",
        "URL转Markdown",
        {
          "type": "regex",
          "label": "URL 转 Markdown",
          "match": "/^https?:\\/\\/\\S+$/i",
          "minLength": 7,
          "maxLength": 1024
        }
      ]
    },
    {
      "code": "arxiv2md",
      "explain": "按文献标题查 CrossRef 并生成 Markdown",
      "cmds": [
        "arxiv",
        "论文搜索",
        "查文献",
        {
          "type": "over",
          "label": "查询文献并生成 Markdown",
          "exclude": "/^https?:\\/\\//i",
          "minLength": 4,
          "maxLength": 256
        }
      ]
    }
  ]
}
